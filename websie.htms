<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kaava Nutrition | Electric Kinetic</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Russo+One&family=Saira:wght@300;400;600&family=Oswald:wght@400;700&display=swap" rel="stylesheet">

    <style>
        /* --- VARIABLES --- */
        :root {
            /* Dark Mode Defaults */
            --bg-color: #050505; 
            --bg-card: rgba(15, 20, 28, 0.9);
            --text-main: #ffffff;
            --text-muted: #a0b0c0;
            
            --brand-blue: #29B6F6;    
            --brand-gold: #FDD835;    
            
            --glow-blue: rgba(41, 182, 246, 0.6);
            --glow-gold: rgba(253, 216, 53, 0.6);
            --shadow-soft: 0 20px 50px rgba(0, 0, 0, 0.9);
            
            --nav-bg: rgba(5, 5, 5, 0.95);
            --card-border: rgba(255, 255, 255, 0.1);
            
            --font-head: 'Russo One', sans-serif;
            --font-body: 'Saira', sans-serif;

            /* Aurora Gradients */
            --clr-1: #00c2ff; 
            --clr-2: #33ff8c; 
            --clr-3: #ffc640; 
            --clr-4: #e54cff;
        }

        /* Light Mode Overrides */
        body.light-mode {
            --bg-color: #f0f4f8; 
            --bg-card: #ffffff;
            --text-main: #2d3748;
            --text-muted: #4a5568;
            --nav-bg: rgba(255, 255, 255, 0.95);
            --card-border: rgba(0,0,0,0.1);
            --brand-blue: #0277BD; 
            --brand-gold: #F9A825; 
        }

        * { margin: 0; padding: 0; box-sizing: border-box; scroll-behavior: smooth; }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: var(--font-body);
            overflow-x: hidden;
            transition: background-color 0.5s ease;
        }
        
        body.no-scroll { overflow: hidden; }

        h1, h2, h3 { font-family: var(--font-head); text-transform: uppercase; color: var(--text-main); line-height: 1.2; }

        /* --- NAVIGATION --- */
        nav {
            position: fixed; top: 0; width: 100%; padding: 20px 50px;
            display: flex; justify-content: space-between; align-items: center;
            z-index: 1000; background: var(--nav-bg); backdrop-filter: blur(15px);
            border-bottom: 2px solid var(--brand-gold);
            transition: 0.5s;
        }
        .logo { font-size: 1.6rem; font-family: var(--font-head); color: var(--text-main); display: flex; align-items: center; gap: 10px; }
        .logo svg { width: 24px; height: 24px; fill: var(--brand-gold); }
        .nav-links { display: flex; gap: 40px; }
        .nav-links a { color: var(--text-muted); text-decoration: none; font-weight: 600; text-transform: uppercase; transition: 0.3s; }
        .nav-links a:hover { color: var(--brand-blue); }
        .theme-toggle { background: transparent; border: 2px solid var(--brand-blue); color: var(--brand-blue); padding: 8px 15px; border-radius: 20px; cursor: pointer; font-weight: bold; }
        .theme-toggle:hover { background: var(--brand-blue); color: white; box-shadow: 0 0 15px var(--glow-blue); }

        /* --- BACKGROUND --- */
        #canvas-container { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; pointer-events: none; }

        /* --- HERO SECTION --- */
        #hero { height: 150vh; position: relative; }
        
        .kinetic-wrapper { 
            position: fixed; top: 50%; left: 50%; 
            transform: translate(-50%, -50%); 
            width: 100%; text-align: center; z-index: 5; 
            pointer-events: none; 
        }

        /* Split Text Container */
        .split-text { 
            position: relative; display: inline-block; 
            font-size: 8vw; line-height: 1; 
            padding: 30px; 
            background: transparent; 
            color: transparent; /* Hide base text */
            user-select: none;
        }

        /* Aurora Text Parts */
        .text-part {
            position: absolute; left: 0; width: 100%; display: block; 
            z-index: 5; transition: transform 0.1s linear;
            
            /* Gradient Text */
            background-image: 
                radial-gradient(circle at 20% 50%, var(--clr-1), transparent 50%),
                radial-gradient(circle at 80% 50%, var(--clr-2), transparent 50%),
                radial-gradient(circle at 50% 20%, var(--clr-3), transparent 50%),
                radial-gradient(circle at 50% 80%, var(--clr-4), transparent 50%);
            background-size: 200% 200%;
            -webkit-background-clip: text; background-clip: text;
            color: transparent;
            animation: aurora-flow 8s ease infinite alternate;
            filter: drop-shadow(0 0 10px rgba(41, 182, 246, 0.3));
        }
        
        @keyframes aurora-flow { 0% { background-position: 0% 50%; } 100% { background-position: 100% 50%; } }

        /* Clipping - Use 50.5% to prevent sub-pixel gaps */
        /* top: 30px matches the padding: 30px of the container */
        .text-part:nth-child(1) { top: 30px; clip-path: polygon(0 0, 100% 0, 100% 50.5%, 0 50.5%); } 
        .text-part:nth-child(2) { top: 30px; clip-path: polygon(0 50.5%, 100% 50.5%, 100% 100%, 0 100%); }

        /* Reveal Bar - NOW PERFECTLY CENTERED */
        .reveal-part {
            position: absolute; 
            top: 50%; left: 0; width: 100%; 
            /* translateY(-50%) centers it vertically in the container */
            transform: translateY(-50%) scaleY(0);
            background: var(--brand-gold); color: #000; 
            font-size: 0.25em; letter-spacing: 0.5em; height: 50px;
            display: flex; align-items: center; justify-content: center; 
            z-index: 20; box-shadow: 0 0 40px var(--brand-gold); 
            font-weight: 700;
            /* REMOVED margin-top: 30px to fix alignment */
        }

        /* Hero Content Fade - LOWERED POSITION */
        .hero-content { 
            position: absolute; 
            bottom: 15%; /* Push significantly lower */
            left: 50%; 
            transform: translateX(-50%); 
            opacity: 0; 
            text-align: center; width: 90%; max-width: 800px; 
            transition: all 0.8s ease; z-index: 10; 
        }
        
        /* Active state moves it slightly up into place */
        .hero-content.active { opacity: 1; transform: translateX(-50%) translateY(-20px); }

        .cta-btn { 
            padding: 20px 60px; background: transparent; color: var(--brand-gold); 
            font-weight: 700; font-family: var(--font-head); text-decoration: none; 
            text-transform: uppercase; display: inline-block; 
            clip-path: polygon(10% 0, 100% 0, 100% 80%, 90% 100%, 0 100%, 0 20%); 
            transition: all 0.3s; border: 2px solid var(--brand-gold); 
            font-size: 1.1rem; letter-spacing: 1px;
        }
        .cta-btn:hover { background: var(--brand-gold); color: #000; box-shadow: 0 0 40px var(--glow-gold); }

        /* --- SECTIONS --- */
        section { padding: 120px 10%; max-width: 1600px; margin: 0 auto; position: relative; }
        .section-header { text-align: center; margin-bottom: 80px; }
        .section-header h2 { 
            font-size: 3.5rem; display: inline-block; position: relative; 
            background: none; -webkit-background-clip: border-box; color: var(--text-main); 
        }
        .section-header h2::after { 
            content: ''; position: absolute; width: 120%; height: 3px; 
            bottom: -5px; left: -10%; background: var(--brand-blue); 
            box-shadow: 0 0 15px var(--brand-blue); 
        }

        /* --- PRODUCTS GRID --- */
        .products-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); 
            gap: 50px; 
            align-items: stretch; 
        }
        
        .card {
            background: var(--bg-card); border-radius: 15px; padding: 50px 35px;
            position: relative; box-shadow: var(--shadow-soft);
            border: 1px solid var(--card-border); border-top: 4px solid var(--brand-blue);
            transform-style: preserve-3d; transition: 0.3s;
            backdrop-filter: blur(10px); cursor: pointer;
            display: flex; flex-direction: column; 
            height: 100%;
        }
        .card:hover { 
            transform: perspective(2000px) translateY(-15px); 
            box-shadow: 0 20px 60px rgba(41, 182, 246, 0.15); 
            border-top-color: var(--brand-gold); 
        }
        .card-icon { 
            font-size: 3.5rem; margin-bottom: 25px; color: #000; 
            background: var(--brand-gold); width: 80px; height: 80px; 
            display: flex; align-items: center; justify-content: center; 
            border-radius: 12px; box-shadow: 0 0 25px var(--glow-gold); 
            transform: translateZ(20px); 
        }
        .card h3 { color: var(--text-main); margin-bottom: 15px; }
        .card p.preview-text { margin-bottom: 30px; flex-grow: 1; }
        .card-link { 
            color: var(--brand-blue); font-weight: 800; text-decoration: none; 
            border-bottom: 1px solid var(--brand-blue); font-size: 0.9rem; 
            display: inline-block;
        }

        /* --- MODAL FIXES --- */
        .card-details-hidden { display: none; }
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9); z-index: 2000; 
            opacity: 0; visibility: hidden; transition: 0.4s;
            backdrop-filter: blur(10px);
        }
        .modal-overlay.active { opacity: 1; visibility: visible; }

        .expanded-card {
            position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.9);
            width: 85vw; max-width: 1100px; height: 80vh;
            background: var(--bg-card);
            border: 1px solid var(--brand-gold);
            border-radius: 20px;
            z-index: 2001; 
            display: grid; grid-template-columns: 1fr 1fr; 
            overflow: hidden;
            opacity: 0; visibility: hidden;
            transition: 0.5s cubic-bezier(0.19, 1, 0.22, 1);
            box-shadow: 0 0 50px rgba(253, 216, 53, 0.2);
        }
        .expanded-card.active { transform: translate(-50%, -50%) scale(1); opacity: 1; visibility: visible; }

        .expanded-image {
            background: linear-gradient(45deg, #1a1a1a, #000);
            position: relative; display: flex; align-items: center; justify-content: center;
            overflow: hidden;
        }
        .octure-shape {
            width: 300px; height: 300px; background: var(--brand-blue);
            clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
            position: relative; animation: float 6s ease-in-out infinite;
        }
        .octure-shape::after {
            content: ''; position: absolute; inset: 10px;
            background: url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAwIiBoZWlnaHQ9IjIwMCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cGF0aCBkPSJNMTAwIDUwIEw1MCAxNTAgTDE1MCAxNTAgWiIgZmlsbD0ibm9uZSIgc3Ryb2tlPSJ3aGl0ZSIgc3Ryb2tlLXdpZHRoPSIyIiAvPjwvc3ZnPg==');
            background-size: cover; opacity: 0.5;
            clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
        }
        @keyframes float { 0%, 100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-20px) rotate(5deg); } }

        .expanded-content { padding: 60px; display: flex; flex-direction: column; justify-content: center; position: relative; }
        
        /* FIXED CLOSE BUTTON */
        .expanded-close {
            position: absolute; top: 20px; right: 20px;
            width: 40px; height: 40px; border-radius: 50%;
            border: 1px solid var(--text-muted); color: var(--text-main);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: 0.3s; font-size: 1.2rem;
            z-index: 3000; 
            background: rgba(0,0,0,0.5);
        }
        .expanded-close:hover { background: var(--brand-gold); border-color: var(--brand-gold); color: black; }

        .spotlight-desc {
            font-size: 1.2rem; line-height: 1.8; color: rgba(255,255,255,0.1); 
            position: relative; cursor: crosshair; margin-top: 30px;
        }
        .spotlight-desc::after {
            content: attr(data-text); position: absolute; left: 0; top: 0; width: 100%; height: 100%;
            color: transparent; 
            background-image: radial-gradient(circle 150px at var(--x) var(--y), var(--text-main) 0%, transparent 50%);
            background-clip: text; -webkit-background-clip: text;
            pointer-events: none;
        }
        body.light-mode .spotlight-desc { color: rgba(0,0,0,0.1); }
        body.light-mode .spotlight-desc::after { background-image: radial-gradient(circle 150px at var(--x) var(--y), #000 0%, transparent 50%); }

        @media (max-width: 900px) {
            .expanded-card { grid-template-columns: 1fr; height: 90vh; width: 90vw; overflow-y: auto; }
            .expanded-image { height: 200px; flex-shrink: 0; }
            .expanded-content { padding: 30px; overflow-y: visible; }
        }

        /* --- R&D & CONTACT --- */
        .rnd-container { display: flex; flex-wrap: wrap; gap: 80px; align-items: center; }
        .rnd-text { flex: 1; min-width: 300px; }
        .rnd-visual {
            flex: 1; min-width: 300px; height: 500px;
            background: linear-gradient(145deg, #0b1829, #000);
            border: 1px solid var(--card-border); border-radius: 20px;
            display: flex; align-items: center; justify-content: center;
            color: var(--brand-gold); font-size: 1.8rem; font-weight: bold;
            box-shadow: 0 0 40px rgba(41, 182, 246, 0.1); position: relative; transform-style: preserve-3d;
        }
        body.light-mode .rnd-visual { background: #ffffff; color: #000; }
        .tech-ring { width: 300px; height: 300px; border: 3px solid rgba(253, 216, 53, 0.3); border-radius: 50%; position: absolute; transform-style: preserve-3d; animation: rotateRing 15s infinite linear; box-shadow: 0 0 20px rgba(253, 216, 53, 0.1); }
        .tech-ring:nth-child(2) { width: 200px; height: 200px; border-color: var(--brand-blue); animation-direction: reverse; animation-duration: 10s; box-shadow: 0 0 20px var(--glow-blue); }
        @keyframes rotateRing { 0% { transform: rotateX(60deg) rotateZ(0deg); } 100% { transform: rotateX(60deg) rotateZ(360deg); } }

        .contact-split { display: grid; grid-template-columns: 1fr 1.5fr; gap: 0; background: var(--bg-card); box-shadow: var(--shadow-soft); border-radius: 20px; overflow: hidden; border: 1px solid var(--card-border); backdrop-filter: blur(10px); }
        .contact-info { background: rgba(0,0,0,0.2); padding: 60px; border-right: 1px solid var(--card-border); }
        .contact-form-wrapper { padding: 60px; }
        
        input, textarea { width: 100%; padding: 20px; margin-bottom: 25px; border: 1px solid var(--card-border); border-radius: 8px; font-family: var(--font-body); background: rgba(0,0,0,0.2); color: var(--text-main); transition: 0.3s; }
        body.light-mode input, body.light-mode textarea { background: #f1f5f9; border: 1px solid #cbd5e1; color: #000; }
        input:focus, textarea:focus { border-color: var(--brand-blue); box-shadow: 0 0 15px rgba(41, 182, 246, 0.2); outline: none; }

        .scroll-3d { opacity: 0; transform: perspective(1000px) translate3d(0, 50px, -50px) rotateX(20deg); transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1); }
        .scroll-3d.visible { opacity: 1; transform: perspective(1000px) translate3d(0, 0, 0) rotateX(0deg); }

        footer { background: var(--bg-card); color: var(--text-muted); padding: 100px 10%; text-align: center; border-top: 1px solid var(--card-border); }
        .scroll-prompt { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); color: var(--brand-blue); letter-spacing: 2px; animation: bounce 2s infinite; font-size: 0.8rem; }
        @keyframes bounce { 0%, 100% { transform: translate(-50%, 0); } 50% { transform: translate(-50%, -10px); } }

        @media (max-width: 768px) { .contact-split { grid-template-columns: 1fr; } .split-text { font-size: 10vw; } .nav-links { display: none; } }
        
        /* Fallback warning */
        #error-toast {
            position: fixed; bottom: 20px; right: 20px; background: #C4471C; color: white; padding: 15px 25px;
            border-radius: 8px; z-index: 9999; display: none; box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            font-family: var(--font-body); font-weight: 600;
        }
    </style>
</head>
<body class="dark-mode">

    <div id="error-toast">Models not found. Showing fallback visuals.</div>
    <div id="canvas-container"></div>

    <nav>
        <div class="logo">
            <svg viewBox="0 0 24 24"><path d="M12 2L2 7v6c0 5.5 3.8 10.4 10 12 6.2-1.6 10-6.5 10-12V7l-10-5zm0 10.9v7c-3.1-1.1-5.6-3.8-6.6-6.9H12v-.1z"/></svg>
            <span>KAAVA</span>
        </div>
        <div class="nav-links">
            <a href="#products">Products</a>
            <a href="#rnd">R&D</a>
            <a href="#contact">Contact</a>
            <button class="theme-toggle" onclick="toggleTheme()">Mode</button>
        </div>
    </nav>

    <section id="hero">
        <div class="kinetic-wrapper" id="kinetic-wrapper">
            <h2 class="split-text">
                KAAVA NUTRITION 
                <span class="text-part">KAAVA NUTRITION</span>
                <span class="text-part">KAAVA NUTRITION</span>
                <span class="reveal-part">SPORTS NUTRITION REDEFINED</span>
            </h2>
        </div>
        <div class="scroll-prompt" id="scroll-arrow">SCROLL TO UNLOCK ↓</div>
        
        <div class="hero-content" id="hero-fade">
            <a href="#products" class="cta-btn">View Products</a>
        </div>
    </section>

    <section id="products">
        <div class="section-header scroll-3d"><h2>OUR PRODUCTS</h2></div>
        <div class="products-grid">
            <!-- Card 1 -->
            <div class="card scroll-3d" onclick="openCard(this)">
                <div class="card-icon">⚡</div>
                <h3>Energy Mixes</h3>
                <p class="preview-text">Powder mixes for pre and post workout. Optimized for Iron, Zinc and Magnesium levels.</p>
                <a class="card-link">CLICK FOR DETAILS</a>
                <div class="card-details-hidden">
                    <div class="detail-title">Premium Energy Mixes</div>
                    <div class="detail-desc">Our flagship energy mixes combine traditional Ayurvedic herbs with sports science. Ingredients include Ashwagandha, electrolytes, and natural caffeine. Move your mouse over this text to see more.</div>
                    <div class="detail-color">#29B6F6</div>
                </div>
            </div>
            <!-- Card 2 -->
            <div class="card scroll-3d" style="transition-delay: 0.1s;" onclick="openCard(this)">
                <div class="card-icon">🥜</div>
                <h3>Nut Butters</h3>
                <p class="preview-text">Made from 'Somnath' groundnuts. Plain, salted, or honey-based variants for muscle repair.</p>
                <a class="card-link">CLICK FOR DETAILS</a>
                <div class="card-details-hidden">
                    <div class="detail-title">Organic Nut Butters</div>
                    <div class="detail-desc">Sourced from the 'Somnath' variety of groundnuts. Available in Classic Roast, Himalayan Pink Salt, and Wild Honey infusions. Perfect for muscle repair. Illuminate this text to learn more.</div>
                    <div class="detail-color">#FDD835</div>
                </div>
            </div>
            <!-- Card 3 -->
            <div class="card scroll-3d" style="transition-delay: 0.2s;" onclick="openCard(this)">
                <div class="card-icon">🛡️</div>
                <h3>Muscle Repair</h3>
                <p class="preview-text">Ashwagandha and Spirulina blend. Helps attain better sleep and natural recovery.</p>
                <a class="card-link">CLICK FOR DETAILS</a>
                <div class="card-details-hidden">
                    <div class="detail-title">Deep Recovery Formula</div>
                    <div class="detail-desc">Recovery is key. Our blend uses Spirulina and Ashwagandha to lower cortisol and promote deep REM cycles naturally. Hover to reveal secrets.</div>
                    <div class="detail-color">#33ff8c</div>
                </div>
            </div>
        </div>
    </section>

    <!-- EXPANDED MODAL -->
    <div class="modal-overlay" id="modal-overlay" onclick="closeCard()"></div>
    <div class="expanded-card" id="expanded-card">
        <div class="expanded-close" onclick="closeCard()">✕</div>
        <div class="expanded-image"><div class="octure-shape" id="modal-shape"></div></div>
        <div class="expanded-content">
            <h2 id="modal-title" style="color: var(--text-main); font-size: 2.5rem; margin-bottom: 20px;">Product Title</h2>
            <div style="width: 50px; height: 4px; background: var(--brand-gold); margin-bottom: 30px;"></div>
            <div class="spotlight-desc" id="modal-desc" data-text=""></div>
            <a href="#contact" onclick="closeCard()" class="cta-btn" style="margin-top: 40px; align-self: flex-start;">Order Now</a>
        </div>
    </div>

    <section id="rnd">
        <div class="section-header scroll-3d"><h2>R&D</h2></div>
        <div class="rnd-container">
            <div class="rnd-text scroll-3d">
                <div style="background: rgba(255,255,255,0.03); border: 1px solid var(--card-border); padding: 30px; border-radius: 15px; margin-bottom:30px;">
                    <p>Collaborating with top scientists and Government agencies to rediscover plant-based nutrition.</p>
                </div>
                <div style="padding: 30px; background: rgba(0,0,0,0.2); border-left: 4px solid var(--brand-gold); border-radius: 0 15px 15px 0;">
                    <h3 style="color: var(--brand-blue); font-size:1.3rem;">MoU with UAS Dharwad</h3>
                    <p style="font-size:0.9rem; margin-top:10px;">Formulations promoting Iron, Calcium, and Magnesium naturally.</p>
                </div>
            </div>
            <div class="rnd-visual scroll-3d">
                <div class="tech-ring"></div><div class="tech-ring"></div>
                <div style="z-index: 2; text-align: center; text-shadow: 0 0 20px rgba(0,0,0,0.8);">INSPIRED BY AYURVEDA<br>BACKED BY SCIENCE</div>
            </div>
        </div>
    </section>

    <section id="contact">
        <div class="contact-split scroll-3d">
            <div class="contact-info">
                <h2>Contact Us</h2>
                <p style="margin-bottom: 40px;">Reach out to us for all your nutrition needs.</p>
                <p style="color:var(--text-muted); margin-bottom: 20px;">✉️ support@kaavanutrition.in</p>
                <p style="color:var(--text-muted);">📞 98452 01442</p>
            </div>
            <div class="contact-form-wrapper">
                <form>
                    <label style="color:var(--brand-blue); font-weight:bold; font-size:0.8rem;">EMAIL</label>
                    <input type="email" placeholder="athlete@example.com">
                    <label style="color:var(--brand-blue); font-weight:bold; font-size:0.8rem;">MESSAGE</label>
                    <textarea rows="4" placeholder="How can we help?"></textarea>
                    <button type="submit" class="cta-btn" style="width:100%; border:none; cursor:pointer;">Submit</button>
                </form>
            </div>
        </div>
    </section>

    <footer>
        <div style="font-family: var(--font-head); font-size: 2rem; color: var(--brand-gold); margin-bottom:20px;">KAAVA NUTRITION</div>
        <p>© 2024. All rights reserved.</p>
    </footer>

    <!-- Three.js and GLTFLoader (moved to end of body) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r146/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.146.0/examples/js/loaders/GLTFLoader.js"></script>

    <script>
        const modalOverlay = document.getElementById('modal-overlay');
        const expandedCard = document.getElementById('expanded-card');
        const modalTitle = document.getElementById('modal-title');
        const modalDesc = document.getElementById('modal-desc');
        const modalShape = document.getElementById('modal-shape');

        function openCard(card) {
            const hiddenData = card.querySelector('.card-details-hidden');
            const title = hiddenData.querySelector('.detail-title').innerText;
            const desc = hiddenData.querySelector('.detail-desc').innerHTML;
            const descText = hiddenData.querySelector('.detail-desc').innerText;
            const color = hiddenData.querySelector('.detail-color').innerText;

            modalTitle.innerText = title;
            modalDesc.innerHTML = desc;
            modalDesc.setAttribute('data-text', descText);
            modalShape.style.background = color;

            modalOverlay.classList.add('active');
            expandedCard.classList.add('active');
            document.body.classList.add('no-scroll');
        }

        function closeCard() {
            modalOverlay.classList.remove('active');
            expandedCard.classList.remove('active');
            document.body.classList.remove('no-scroll');
        }

        modalDesc.addEventListener('mousemove', (e) => {
            const rect = modalDesc.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            modalDesc.style.setProperty('--x', x + 'px');
            modalDesc.style.setProperty('--y', y + 'px');
        });

        const body = document.body;
        let isLight = false;
        function toggleTheme() {
            isLight = !isLight;
            body.classList.toggle('light-mode');
            if(window.updateSceneColors) window.updateSceneColors(isLight);
        }

        const kineticWrapper = document.getElementById('kinetic-wrapper');
        const spanTop = document.querySelector('.text-part:nth-child(1)');
        const spanBottom = document.querySelector('.text-part:nth-child(2)');
        const spanReveal = document.querySelector('.reveal-part');
        const heroFade = document.getElementById('hero-fade');
        const scrollArrow = document.getElementById('scroll-arrow');

        window.addEventListener('scroll', () => {
            const scrollY = window.scrollY;
            const windowH = window.innerHeight;
            let progress = Math.min(scrollY / (windowH * 0.4), 1);
            // Increased separation to 50px for better gap
            const separation = progress * 50; 
            
            spanTop.style.transform = `translateY(-${separation}px)`;
            spanBottom.style.transform = `translateY(${separation}px)`;
            spanReveal.style.transform = `translateY(-50%) scaleY(${progress})`;

            if(progress > 0.8 && scrollY < windowH * 0.9) {
                heroFade.classList.add('active');
                scrollArrow.style.opacity = '0';
            } else {
                heroFade.classList.remove('active');
                scrollArrow.style.opacity = '1';
            }

            // Adjusted fade logic to make Kaava text fade earlier
            let fadeStart = windowH * 0.2; // Start fading sooner
            let fadeEnd = windowH * 0.7;   // Gone sooner
            let opacity = 1;
            if (scrollY > fadeStart) {
                opacity = 1 - ((scrollY - fadeStart) / (fadeEnd - fadeStart));
                opacity = Math.max(0, Math.min(1, opacity));
            }
            kineticWrapper.style.opacity = opacity;
            kineticWrapper.style.visibility = opacity <= 0 ? 'hidden' : 'visible';
        });

        const initThree = () => {
            const container = document.getElementById('canvas-container');
            const scene = new THREE.Scene();
            scene.fog = new THREE.FogExp2(0x050505, 0.025);
            const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.z = 12; // Camera further back for models
            const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            container.appendChild(renderer.domElement);

            // Lighting
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
            scene.add(ambientLight);
            
            const spotLight1 = new THREE.SpotLight(0x29B6F6, 2); // Brand Blue
            spotLight1.position.set(-10, 10, 10);
            spotLight1.angle = Math.PI / 4;
            spotLight1.penumbra = 0.5;
            scene.add(spotLight1);

            const spotLight2 = new THREE.SpotLight(0xFDD835, 2); // Brand Gold
            spotLight2.position.set(10, 10, 10);
            spotLight2.angle = Math.PI / 4;
            spotLight2.penumbra = 0.5;
            scene.add(spotLight2);

            // Fallback athlete creator
            const createFallbackAthlete = (type) => {
                const group = new THREE.Group();
                // Body
                const bodyGeo = new THREE.CapsuleGeometry(0.5, 1.5, 4, 8);
                const bodyMat = new THREE.MeshStandardMaterial({ 
                    color: type === 'sprinter' ? 0x29B6F6 : 0xFDD835, 
                    roughness: 0.3, metalness: 0.8 
                });
                const body = new THREE.Mesh(bodyGeo, bodyMat);
                body.position.y = 1;
                group.add(body);
                
                // Head
                const headGeo = new THREE.SphereGeometry(0.4, 16, 16);
                const head = new THREE.Mesh(headGeo, bodyMat);
                head.position.y = 2.2;
                group.add(head);

                if(type === 'cricket') {
                    // Bat
                    const batGeo = new THREE.BoxGeometry(0.3, 1.2, 0.1);
                    const batMat = new THREE.MeshStandardMaterial({ color: 0x8B4513 });
                    const bat = new THREE.Mesh(batGeo, batMat);
                    bat.position.set(0.6, 0.8, 0.3);
                    bat.rotation.z = -0.2;
                    group.add(bat);
                }
                return group;
            };

            // GLTFLoader for Athletes with Fallback
            const loader = new THREE.GLTFLoader();
            let sprinter, cricketPlayer;

            // Helper to load with fallback
            const loadModel = (url, type, pos, rot, scale) => {
                // 1. Create and add fallback IMMEDIATELY
                const fallback = createFallbackAthlete(type);
                fallback.position.set(pos.x, pos.y, pos.z);
                fallback.rotation.y = rot;
                // Store reference to animate it
                if (type === 'sprinter') sprinter = fallback;
                else cricketPlayer = fallback;
                scene.add(fallback);

                // 2. Try to load real model to replace fallback
                try {
                    loader.load(url, (gltf) => {
                        // Success! Remove fallback, add real model
                        scene.remove(fallback);
                        
                        const model = gltf.scene;
                        model.position.set(pos.x, pos.y, pos.z);
                        model.scale.set(scale, scale, scale);
                        model.rotation.y = rot;
                        scene.add(model);
                        
                        // Update reference for animation
                        if (type === 'sprinter') sprinter = model;
                        else cricketPlayer = model;
                        
                    }, undefined, (err) => {
                        console.warn(`Model load failed for ${url}. Keeping fallback.`);
                        // Toast logic here if needed, but fallback is already visible so maybe not necessary to annoy user
                    });
                } catch (e) {
                    console.warn("GLTFLoader crashed (likely due to environment). Keeping fallback.");
                }
            };

            // Load Sprinter (Left side)
            loadModel('sprinter 3d model.glb', 'sprinter', {x: -6, y: -3, z: 0}, Math.PI / 4, 3);

            // Load Cricket Player (Right side)
            loadModel('cricket player 3d model.glb', 'cricket', {x: 6, y: -3, z: 0}, -Math.PI / 4, 3);

            // Stars Background (Keep it, maybe slower/subtler)
            const geometry = new THREE.BufferGeometry();
            const count = 2000;
            const posArray = new Float32Array(count * 3);
            for(let i = 0; i < count * 3; i++) {
                posArray[i] = (Math.random() - 0.5) * 100;
            }
            geometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
            const material = new THREE.PointsMaterial({ size: 0.05, color: 0xffffff, transparent: true, opacity: 0.5 });
            const stars = new THREE.Points(geometry, material);
            scene.add(stars);

            // Theme Update Helper
            window.updateSceneColors = (light) => {
                const bgColor = light ? 0xf0f4f8 : 0x050505;
                scene.fog.color.setHex(bgColor);
                
                // Adjust lights for light mode?
                spotLight1.intensity = light ? 1.5 : 2;
                spotLight2.intensity = light ? 1.5 : 2;
            };

            // Mouse Parallax
            let mouseX = 0, mouseY = 0;
            document.addEventListener('mousemove', (e) => {
                mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
                mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
            });

            const animate = () => {
                requestAnimationFrame(animate);
                
                // Animate Athletes (Breathing/Idle motion)
                const time = Date.now() * 0.001;
                if (sprinter) {
                    sprinter.position.y = -3 + Math.sin(time) * 0.1; // Bobbing
                    sprinter.rotation.y = Math.PI / 4 + Math.sin(time * 0.5) * 0.05; // Subtle Turn
                }
                if (cricketPlayer) {
                    cricketPlayer.position.y = -3 + Math.sin(time + 1) * 0.1; // Offset bobbing
                    cricketPlayer.rotation.y = -Math.PI / 4 + Math.sin(time * 0.5 + 1) * 0.05;
                }

                // Subtle Star movement
                stars.rotation.z += 0.0005;

                // Camera Parallax
                camera.position.x += (mouseX * 2 - camera.position.x) * 0.05;
                camera.position.y += (-mouseY * 2 - camera.position.y + 5) * 0.05; // Keep slight elevation (+5)
                camera.lookAt(0, 0, 0);

                renderer.render(scene, camera);
            };
            animate();

            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });
        };
        // Wait for DOM content to be loaded before initializing Three.js
        document.addEventListener('DOMContentLoaded', initThree);

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
        }, { threshold: 0.1 });
        document.querySelectorAll('.scroll-3d').forEach(el => observer.observe(el));
    </script>
</body>
</html>